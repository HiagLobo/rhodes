{
  "name": "@rhodes/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend Fastify — API, agendador e acesso ao SQLite",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "seed:dev": "tsx src/db/seed.ts",
    "seed:catalogo": "tsx src/db/seed-catalogo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@node-rs/argon2": "^2.0.2",
    "@rhodes/shared": "^0.1.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.15.2",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdfkit": "^0.17.6",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0"
  }
}
